# Git Ignore Rules for RaiTech Portfolio

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
.next/
out/

# IDE and Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.env.local
.env.*.local

# Environment files (keep .env.example)
.env
.env.production.local
.env.development.local
.env.test.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp

# OS files
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# Cache
.cache/
.eslintcache

# Testing
coverage/
.nyc_output/

# Sensitive data
secrets.json
credentials.json
*.key
*.pem

# Static file caches
.next/cache/
.nuxt/dist/

# Local testing artifacts
test-results/
test-coverage/
